APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=your_secure_mysql_password_here

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PREFIX=smartsprouts_

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

DEEPL_API_KEY=

TRANSLATION_CACHE_ENABLED=true
TRANSLATION_CACHE_TTL=2592000
TRANSLATION_CACHE_PREFIX=translation_cache_

ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_DEFAULT_VOICE=hpp4J3VqNfWAUOO0d1Us
ELEVENLABS_TTS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_REQUEST_TIMEOUT=30
ELEVENLABS_CONNECT_TIMEOUT=10
ELEVENLABS_RETRY_TIMES=3
ELEVENLABS_RETRY_SLEEP=1000

TTS_STORAGE_ENABLED=true
TTS_STORAGE_DISK=public
TTS_STORAGE_PATH_PREFIX=tts/audio

# Ukrainian TTS Service
UKRAINIAN_TTS_BASE_URL=http://ukrainian-tts:5001
UKRAINIAN_TTS_SPEAKER=lada

# Active TTS provider: elevenlabs | kokoro | ukrainian_tts | locale_dispatch
# Use locale_dispatch in local dev to route uk→ukrainian_tts, en/es→kokoro
TTS_PROVIDER=locale_dispatch

# Locale-dispatch sub-provider mapping (only used when TTS_PROVIDER=locale_dispatch)
TTS_PROVIDER_UK=ukrainian_tts
TTS_PROVIDER_EN=kokoro
TTS_PROVIDER_ES=kokoro
TTS_LOCALE_DISPATCH_FALLBACK=elevenlabs

# Kokoro TTS Service (dev-only, self-hosted)
KOKORO_TTS_BASE_URL=http://kokoro-tts:8880
KOKORO_TTS_DEFAULT_VOICE=af_heart
KOKORO_TTS_VOICE_EN=af_heart
KOKORO_TTS_VOICE_ES=ef_dora
KOKORO_TTS_SPEED=1.0
KOKORO_TTS_REQUEST_TIMEOUT=60
KOKORO_TTS_CONNECT_TIMEOUT=10
KOKORO_TTS_RETRY_TIMES=3
KOKORO_TTS_RETRY_SLEEP=2000
