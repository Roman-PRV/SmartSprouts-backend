APP_NAME=SmartSprouts
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
QUEUE_WORKER_TIMEOUT=120
QUEUE_WORKER_QUEUES=tts,default
QUEUE_RETRY_AFTER=135
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PREFIX=smartsprouts_

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME=SmartSprouts

OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

DEEPL_API_KEY=

TRANSLATION_CACHE_ENABLED=true
TRANSLATION_CACHE_TTL=2592000
TRANSLATION_CACHE_PREFIX=translation_cache_

ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_DEFAULT_VOICE=hpp4J3VqNfWAUOO0d1Us
ELEVENLABS_TTS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_REQUEST_TIMEOUT=30
ELEVENLABS_CONNECT_TIMEOUT=10
ELEVENLABS_RETRY_TIMES=3
ELEVENLABS_RETRY_SLEEP=1000

TTS_STORAGE_ENABLED=true
TTS_STORAGE_DISK=public
TTS_STORAGE_PATH_PREFIX=tts/audio
TTS_AUTO_GENERATE_ENABLED=true
TTS_QUEUE=tts

# Active TTS provider: elevenlabs | ukrainian_tts | locale_dispatch
TTS_PROVIDER=elevenlabs

# Ukrainian TTS Service (optional, enable with --profile tts)
UKRAINIAN_TTS_BASE_URL=http://ukrainian-tts:5001
UKRAINIAN_TTS_SPEAKER=lada

# Locale-dispatch sub-provider mapping (only used when TTS_PROVIDER=locale_dispatch)
TTS_PROVIDER_UK=ukrainian_tts
TTS_PROVIDER_EN=elevenlabs
TTS_PROVIDER_ES=elevenlabs
TTS_LOCALE_DISPATCH_FALLBACK=elevenlabs

TTS_MAX_TEXT_LENGTH=2000
TTS_CHUNK_SIZE=200
