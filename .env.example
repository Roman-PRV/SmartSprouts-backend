MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=laravel
MYSQL_USER=laravel
MYSQL_PASSWORD=your_secure_mysql_password_here

REDIS_PASSWORD=your_secure_redis_password_here

# Host port for Redis — exposed only in development (default: 6379).
# Not published in production (docker-compose.prod.yml).
REDIS_PORT=6379

TTS_PORT=5001

# Application environment.
# Controls Laravel operating mode AND triggers auto-migrations on container start.
#
#   local       — Development. Xdebug enabled. Migrations NOT run automatically.
#   production  — Production. Xdebug disabled. `php artisan migrate --force`
#                 runs automatically on every container start.
#
# This value is overridden by docker-compose.override.yml (local)
# and docker-compose.prod.yml (production). You only need to set it
# manually when running the container standalone.
APP_ENV=local