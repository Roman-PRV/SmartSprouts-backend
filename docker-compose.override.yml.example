# ─────────────────────────────────────────────────────────────────────────────
# Copy or rename this file to docker-compose.override.yml to have it
# automatically merged by Docker Compose when running: docker compose up
# Do NOT use this file in production as-is.
# ─────────────────────────────────────────────────────────────────────────────

services:
  laravel:
    build:
      target: dev          # Builds the 'dev' stage (includes Xdebug)
    environment:
      APP_ENV: local
      APP_DEBUG: true
    volumes:
      - ./laravel:/var/www                      # Hot-reload: source code from host
      - vendor_data:/var/www/vendor             # Preserve vendor across rebuilds
      - ./laravel/public:/var/www/public        # Override named volume → bind-mount for dev hot-reload (mirrors nginx override)
      - ./laravel/storage:/var/www/storage      # Override named volume → bind-mount for dev (logs visible on host)
    extra_hosts:
      - "host.docker.internal:host-gateway"     # Required for Xdebug client_host
    networks:
      - app-network
      - dev-local-network                       # Connects to Kokoro TTS and other local dev services

  queue-worker:
    build:
      target: dev
    env_file:
      - ./laravel/.env  # dev only — prod injects vars via Coolify
    volumes:
      - ./laravel:/var/www
      - vendor_data:/var/www/vendor
      - ./laravel/storage:/var/www/storage      # Override named volume → bind-mount for dev
    extra_hosts:
      - "host.docker.internal:host-gateway"     # Required for Xdebug client_host
    networks:
      - app-network
      - dev-local-network

  mysql:
    ports:
      - "127.0.0.1:3306:3306"  # Expose to host for local DB clients (TablePlus, DBeaver)

  nginx:
    ports:
      - "3000:80"                              # Expose to host for local development
    volumes:
      - ./nginx/default.conf:/etc/nginx/conf.d/default.conf  # hot-reload of nginx config in dev
      - ./laravel/public:/var/www/public:ro    # override named volume for dev hot-reload
      - ./laravel/storage:/var/www/storage:ro  # override named volume for dev

  redis:
    ports:
      - "127.0.0.1:${REDIS_PORT:-6379}:6379"   # Expose to host for local Redis inspection

volumes:
  vendor_data:

networks:
  dev-local-network:
    external: true  # Shared with independent dev containers (e.g. kokoro-tts).
                    # Create once: docker network create dev-local-network

