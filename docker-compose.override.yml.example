# ─────────────────────────────────────────────────────────────────────────────
# Copy or rename this file to docker-compose.override.yml to have it
# automatically merged by Docker Compose when running: docker compose up
# Do NOT use this file in production as-is.
# ─────────────────────────────────────────────────────────────────────────────

services:
  laravel:
    image: smartsprouts-backend:dev
    build:
      context: ./laravel
      dockerfile: docker/Dockerfile
      target: dev
    environment:
      APP_ENV: local
      APP_DEBUG: true
    volumes:
      - ./laravel:/var/www
      - vendor_data:/var/www/vendor
      - ./laravel/public:/var/www/public
      - ./laravel/storage:/var/www/storage
    extra_hosts:
      - "host.docker.internal:host-gateway"
    networks:
      - app-network
      - dev-local-network

  queue-worker:
    image: smartsprouts-backend:dev
    build:
      context: ./laravel
      dockerfile: docker/Dockerfile
      target: dev
    env_file:
      - ./laravel/.env
    volumes:
      - ./laravel:/var/www
      - vendor_data:/var/www/vendor
      - ./laravel/storage:/var/www/storage
    extra_hosts:
      - "host.docker.internal:host-gateway"
    networks:
      - app-network
      - dev-local-network

  mysql:
    ports:
      - "127.0.0.1:3306:3306"  # Expose to host for local DB clients (TablePlus, DBeaver)

  nginx:
    ports:
      - "3000:80"                              # Expose to host for local development
    volumes:
      - ./nginx/default.conf:/etc/nginx/conf.d/default.conf  # hot-reload of nginx config in dev
      - ./laravel/public:/var/www/public:ro    # override named volume for dev hot-reload
      - ./laravel/storage:/var/www/storage:ro  # override named volume for dev

  redis:
    ports:
      - "127.0.0.1:${REDIS_PORT:-6379}:6379"   # Expose to host for local Redis inspection

  # Self-hosted Ukrainian TTS — dev only. Enable via:
  #   docker compose --profile tts up
  # Production uses TTS_PROVIDER=elevenlabs and does not include this service.
  ukrainian-tts:
    profiles: ["tts"]
    build:
      context: ./python-services/ukrainian-tts
      dockerfile: Dockerfile
    restart: unless-stopped
    ports:
      - "5001:5001"
    environment:
      - TTS_MAX_TEXT_LENGTH=${TTS_MAX_TEXT_LENGTH:-2000}
      - TTS_CHUNK_SIZE=${TTS_CHUNK_SIZE:-200}
    networks:
      - app-network

volumes:
  vendor_data:

networks:
  dev-local-network:
    external: true  # Shared with independent dev containers (e.g. kokoro-tts).
                    # Create once: docker network create dev-local-network

